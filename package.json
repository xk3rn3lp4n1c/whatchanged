{
  "name": "whatchanged",
  "displayName": "whatchanged",
  "description": "Generate Conventional Commits from staged changes using local Ollama",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commit-helper.generateCommitMessage",
        "title": "Commit Helper: Generate Commit Message"
      }
    ],
    "configuration": {
      "title": "Commit Helper",
      "properties": {
        "commitHelper.ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the Ollama server."
        },
        "commitHelper.ollama.model": {
          "type": "string",
          "default": "qwen2.5-coder",
          "description": "Ollama model used to generate commit messages."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/node-fetch": "^2.6.13",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
